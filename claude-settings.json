{
  "permissions": {
    "deny": [
      "Bash(git push:*)",
      "Bash(git push)"
    ],
    "defaultMode": "acceptEdits",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal -i dialog-question 'Claude Code' 'Permission required'"
          }
        ]
      },
      {
        "matcher": "idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send -u normal -i utilities-terminal 'Claude Code' 'Waiting for input'"
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "model": "claude-opus-4-6"
}
